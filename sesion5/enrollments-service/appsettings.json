{
  "Logging": {
    "LogLevel": {
      "Default":                "Information",
      "Microsoft.AspNetCore":   "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=enrollments-db;Port=3306;Database=enrollments_db;User=enrollments_user;Password=enrollments_pass;"
  },
  "Services": {
    "StudentsServiceUrl": "http://students-api:8080"
  },
  "RabbitMq": {
    "Host":                    "rabbitmq",
    "Port":                    5672,
    "User":                    "admin",
    "Password":                "admin_pass",
    "VirtualHost":             "/",
    "EnrollmentsExchange":     "enrollments-events",
    "StudentsExchange":        "students-events",
    "StudentDeactivatedQueue": "enrollments.student-deactivated",
    "StudentCreatedQueue":     "enrollments.student-created"
  }
}
